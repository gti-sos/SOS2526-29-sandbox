{
  "name": "sos2526-29",
  "version": "1.0.0",
  "description": "Proyecto SOS2526-29",
  "homepage": "https://github.com/gti-sos/SOS2526-29#readme",
  "bugs": {
    "url": "https://github.com/gti-sos/SOS2526-29/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gti-sos/SOS2526-29.git"
  },
  "license": "ISC",
  "author": "Alberto Lirola",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "cd frontend-group && npm run build",
    "dev-front": "cd frontend-group && npm run dev -- --open",
    "test-natural-disasters": "newman run ./tests/ALG/pruebas-alg.json -e ./tests/ALG/local_env.json",
    "test-citys-stats": "newman run ./tests/LCC/pruebas-lcc.json -e ./tests/LCC/local_env.json",
    "test-citys-stats-v2": "newman run ./tests/LCC/pruebas-lcc-v2.json -e ./tests/LCC/local_env_v2.json",
    "test-wine-stats": "newman run ./tests/RMP/pruebas-rmp.json -e ./tests/RMP/local_env.json",
    "test-ALG": "start-server-and-test start http://localhost:10000/api/v2/natural-disasters \"npm run test-natural-disasters\"",
    "test-LCC": "start-server-and-test start http://localhost:10000/api/v1/citys-stats \"npm run test-citys-stats\"",
    "test-LCC-v2": "start-server-and-test start http://localhost:10000/api/v2/citys-stats \"npm run test-citys-stats-v2\"",
    "test-LCC-e2e": "playwright test -c tests/LCC/playwright.config.js",
    "test-RMP": "start-server-and-test start http://localhost:10000/api/v1/wine-stats \"npm run test-wine-stats\"",
    "test-online-ALG": "newman run ./tests/ALG/pruebas-alg.json -e ./tests/ALG/online_env.json",
    "test-online-LCC": "newman run ./tests/LCC/pruebas-lcc.json -e ./tests/LCC/online_env.json",
    "test-online-LCC-v2": "newman run ./tests/LCC/pruebas-lcc-v2.json -e ./tests/LCC/online_env_v2.json",
    "test": "npm run test-ALG && npm run test-RMP && npm run test-LCC"
  },
  "dependencies": {
    "@highcharts/map-collection": "^2.3.2",
    "@seald-io/nedb": "^4.1.2",
    "cool-ascii-faces": "^1.3.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "highcharts": "^12.6.0",
    "leaflet": "^1.9.4",
    "svelte": "^5.54.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "newman": "^6.2.2",
    "start-server-and-test": "^2.1.5"
  }
}
