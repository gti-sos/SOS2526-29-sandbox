              "});",
              "var data = pm.response.json();",
              "pm.test('La busqueda por q devuelve seoul', function () {",
              "    pm.expect(Array.isArray(data)).to.eql(true);",
              "    pm.expect(data.length).to.eql(1);",
              "    pm.expect(data[0].city).to.eql('seoul');",
              "    pm.expect(data[0].country).to.eql('south-korea');",
              "});"
